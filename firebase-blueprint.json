{
  "rules": [
    {
      "collection": "workspaces",
      "fields": {
        "name": "string",
        "ownerId": "string",
        "members": "list"
      },
      "read": "isAuthenticated() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.members)",
      "write": "isAuthenticated() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.members)"
    },
    {
      "collection": "collections",
      "fields": {
        "workspaceId": "string",
        "name": "string",
        "requests": "list",
        "mockConfig": "map"
      },
      "read": "isAuthenticated()",
      "write": "isAuthenticated()"
    },
    {
      "collection": "environments",
      "fields": {
        "workspaceId": "string",
        "name": "string",
        "variables": "list"
      },
      "read": "isAuthenticated()",
      "write": "isAuthenticated()"
    },
    {
      "collection": "deployments",
      "fields": {
        "workspaceId": "string",
        "collectionId": "string",
        "collectionName": "string",
        "version": "string",
        "createdAt": "string",
        "requests": "list"
      },
      "read": "true",
      "write": "isAuthenticated()"
    }
  ]
}
